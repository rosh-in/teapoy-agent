# ============================================================
# TEAPOY AGENT - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ------------------------------------------------------------
# AI / LLM
# ------------------------------------------------------------

# Google Gemini API key (required when USE_OLLAMA=false)
GEMINI_API_KEY=

# Gemini model to use (default shown)
GEMINI_MODEL=gemini-2.5-flash-lite

# Set to true to use a local Ollama instance instead of Gemini
USE_OLLAMA=false

# Ollama server address (only needed if USE_OLLAMA=true)
OLLAMA_HOST=http://192.168.1.43:11434

# Ollama model name (only needed if USE_OLLAMA=true)
OLLAMA_MODEL=gemma2:2b

# ------------------------------------------------------------
# Audio / Webhooks (optional - for Mission Impossible theme)
# ------------------------------------------------------------

# Zapier webhook URL to trigger audio playback when a mission prints
ZAPIER_WEBHOOK_URL=

# Zapier webhook URL to stop audio playback after the track ends
ZAPIER_STOP_WEBHOOK_URL=

# ------------------------------------------------------------
# Identity
# ------------------------------------------------------------

# Name printed on every mission briefing as the agent
AGENT_NAME=Agent Roshin

# ------------------------------------------------------------
# Quiet Hours  (24-hour clock, local time)
# Missions are created but printing is deferred until morning
# ------------------------------------------------------------

# Hour to start quiet hours (default: 22 = 10 PM)
QUIET_START=22

# Hour to end quiet hours (default: 6 = 6 AM)
QUIET_END=6
